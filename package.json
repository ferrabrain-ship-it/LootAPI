{
  "name": "mineloot-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node scripts/installPlaywrightRailway.mjs",
    "start": "node dist/server.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "db:init:agents": "tsx src/scripts/initAgentStatsDb.ts",
    "db:init:protocol": "tsx src/scripts/initProtocolIndexDb.ts",
    "sync:agents:once": "tsx src/jobs/agentStatsSync.ts --once",
    "sync:protocol:once": "tsx src/jobs/protocolIndexer.ts --once",
    "worker:agent-stats": "tsx src/jobs/agentStatsSync.ts",
    "worker:protocol-indexer": "tsx src/jobs/protocolIndexer.ts",
    "worker:lootpot": "tsx src/jobs/lootpotNotifier.ts",
    "worker:lootpot:test": "LOOTPOT_WORKER_TEST=true tsx src/jobs/lootpotNotifier.ts",
    "worker:discord-price": "tsx src/jobs/discordPriceWorker.ts",
    "worker:discord-price:once": "tsx src/jobs/discordPriceWorker.ts --once",
    "worker:discord-metrics": "tsx src/jobs/discordMetricBotsWorker.ts",
    "worker:discord-price-command": "tsx src/jobs/discordPriceCommandBot.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@supabase/supabase-js": "^2.49.1",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "playwright": "^1.54.2",
    "pg": "^8.20.0",
    "viem": "^2.37.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.18.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
